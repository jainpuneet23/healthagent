# Copy this file to .env and fill in your values
# Never commit your actual .env file to git

# Get this from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Make up a strong random password (used to manually trigger AI analysis)
ADMIN_SECRET=change-me-to-something-random

# Leave as-is for SQLite (simple file-based database, no setup needed)
DATABASE_URL=sqlite:///health.db
